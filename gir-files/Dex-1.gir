    <function name="bus_own_name_on_connection"
              c:identifier="dex_bus_own_name_on_connection"
              version="1.1">
      <doc xml:space="preserve"
           filename="src/dex-gdbus.c"
           line="664">Wrapper for [func@Gio.bus_own_name].

Asks the D-Bus broker to own the well-known name @name on the connection @connection.

@out_name_acquired_future is a future that awaits owning the name and either
resolves to true, or rejects with an error.

@out_name_lost_future is a future that rejects when the name was lost.

If either future is canceled, the name will be unowned.</doc>
      <source-position filename="src/dex-gdbus.h" line="79"/>
      <return-value transfer-ownership="none">
        <type name="none" c:type="void"/>
      </return-value>
      <parameters>
        <parameter name="connection" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="src/dex-gdbus.c"
               line="666">The [class@Gio.DBusConnection] to own a name on.</doc>
          <type name="Gio.DBusConnection" c:type="GDBusConnection*"/>
        </parameter>
        <parameter name="name" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="src/dex-gdbus.c"
               line="667">The well-known name to own.</doc>
          <type name="utf8" c:type="const char*"/>
        </parameter>
        <parameter name="flags" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="src/dex-gdbus.c"
               line="668">a set of flags with ownership options.</doc>
          <type name="Gio.BusNameOwnerFlags" c:type="GBusNameOwnerFlags"/>
        </parameter>
        <parameter name="out_name_acquired_future"
                   direction="out"
                   caller-allocates="0"
                   transfer-ownership="full"
                   optional="1"
                   allow-none="1">
          <doc xml:space="preserve"
               filename="src/dex-gdbus.c"
               line="669">a location for the name acquired future</doc>
          <type name="Future" c:type="DexFuture**"/>
        </parameter>
        <parameter name="out_name_lost_future"
                   direction="out"
                   caller-allocates="0"
                   transfer-ownership="full"
                   optional="1"
                   allow-none="1">
          <doc xml:space="preserve"
               filename="src/dex-gdbus.c"
               line="670">a location for the name lost future</doc>
          <type name="Future" c:type="DexFuture**"/>
        </parameter>
      </parameters>
    </function>
